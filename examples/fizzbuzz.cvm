// Classic FizzBuzz (prints numeric codes since we have no strings in VM:
//   -1 = Fizz, -2 = Buzz, -3 = FizzBuzz)
let i = 1;
while (i <= 15) {
    if ((i % 15) == 0) {
        print 0 - 3;
    } else if ((i % 3) == 0) {
        print 0 - 1;
    } else if ((i % 5) == 0) {
        print 0 - 2;
    } else {
        print i;
    }
    i = i + 1;
}
